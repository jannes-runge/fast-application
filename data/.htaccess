# Kompletter Zugriff per Web gesperrt.
Require all denied
# Apache 2.2 Fallback
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>

# Defense-in-Depth: PHP in diesem Verzeichnis nicht ausführen.
# php_flag funktioniert nur mit mod_php; mit PHP-FPM ignoriert der Server diese Zeile
# (schadet dann aber nicht — der Require-all-denied oben bleibt aktiv).
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
<IfModule mod_php7.c>
  php_flag engine off
</IfModule>
<IfModule mod_php8.c>
  php_flag engine off
</IfModule>
