# --- Root .htaccess ---
# Hinweis: <Directory>-Blöcke sind in .htaccess NICHT erlaubt (führen zu 500).

Options -Indexes
AddDefaultCharset UTF-8

# data/ und includes/ per URL sperren
RedirectMatch 404 (?i)^/(data|includes)(/|$)

# Dotfiles, Lock-Datei und .log nie ausliefern
<FilesMatch "(^\.|\.log$)">
  Require all denied
</FilesMatch>

# secrets.php doppelt absichern, falls mal irrtümlich im Root landet
<FilesMatch "^secrets\.php$">
  Require all denied
</FilesMatch>

# Security-Header (Fallback falls nicht via PHP gesetzt)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
